{
    "name": "kreblu/kreblu",
    "description": "A modern, free, open-source CMS built on PHP and MySQL. Community owned, zero restrictions.",
    "type": "project",
    "license": "MIT",
    "homepage": "https://kreblu.org",
    "keywords": ["cms", "content-management", "open-source", "php", "mysql"],
    "authors": [
        {
            "name": "Kreblu Contributors",
            "homepage": "https://kreblu.org/contributors"
        }
    ],
    "require": {
        "php": ">=8.5.0",
        "ext-pdo": "*",
        "ext-mysqli": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-curl": "*",
        "ext-fileinfo": "*",
        "ext-zip": "*",
        "ext-xml": "*",
        "ext-intl": "*",
        "ext-gd": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "Kreblu\\Core\\": "os-core/",
            "Kreblu\\Admin\\": "os-admin/controllers/",
            "Kreblu\\CLI\\": "os-cli/commands/"
        },
        "files": [
            "os-core/Helpers/functions.php",
            "os-core/Helpers/formatting.php",
            "os-core/Helpers/url.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Kreblu\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.5.0"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "lint": "phpcs",
        "lint-fix": "phpcbf",
        "check": [
            "@lint",
            "@analyse",
            "@test"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
