<?xml version="1.0"?>
<ruleset name="Kreblu">
    <description>Kreblu coding standard based on PSR-12</description>

    <!-- What to scan -->
    <file>os-core</file>
    <file>os-admin/controllers</file>
    <file>os-cli/commands</file>
    <file>tests</file>

    <!-- What to ignore -->
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>os-content/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>
    <exclude-pattern>docker/*</exclude-pattern>

    <!-- PSR-12 base -->
    <rule ref="PSR12"/>

    <!-- Line length: warn at 120, error at 200 -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="200"/>
        </properties>
    </rule>

    <!-- Require strict_types declaration in every PHP file -->
    <rule ref="Generic.PHP.RequireStrictTypes"/>
</ruleset>
